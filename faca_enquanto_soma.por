programa
{
/*Escreva um algoritmo que receba vários números
e calcule o somatório desses números. Quando o
usuário digitar zero o algoritmo deve imprimir o
valor do somatório e depois terminar.
❖ Desenhe o fluxograma e faça o código usando:
❖ Faça-enquanto
❖ Enquanto*/
	
	funcao inicio()
	{
		inteiro numero,soma=0
		faca{
			escreva("digite um número")
			leia(numero)
			soma=soma+numero
			}
			enquanto(numero!=0)
			escreva("A soma dos números digitados é", soma)
	}
}
